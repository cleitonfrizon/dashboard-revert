REONIC_BASE_URL=https://api.reonic.de/rest/v2
REONIC_API_KEY=<PREENCHER_Basic_xxxxx>

# ─── N8N SELF-HOSTED ─────────────────────────────────────────────────
N8N_BASE_URL=https://n8n.escalanegociosdigitais.com.br
N8N_API_KEY=<PREENCHER_JWT_token>
N8N_LEGACY_WORKFLOW_ID=dYJBsmLbfhaU5Og0
N8N_NOTIFICATION_WORKFLOW_ID=Qcjrrzy17k2sdq8M

# ─── DASHBOARD ───────────────────────────────────────────────────────
DASHBOARD_DOMAIN=dashboard.escalanegociosdigitais.com.br
DASHBOARD_API_PATH=dashboard/revert
DASHBOARD_API_TOKEN=<gerar_64_chars_random_na_Story_1.2>
DASHBOARD_PASSWORD_RAW=<senha_forte_16+_chars>
VITE_DASHBOARD_PASSWORD_HASH=<bcrypt_da_senha_gerado_na_Story_1.3>

# ─── DEPLOY ──────────────────────────────────────────────────────────
VERCEL_TOKEN=<PREENCHER_via_vercel_tokens_create>
GITHUB_REPO_URL=https://github.com/cleitonfrizon/dashboard-revert.git

# ─── ESCALA — IDENTIDADE ─────────────────────────────────────────────
ESCALA_CNPJ=48.215.104/0001-40
ESCALA_LEGAL_NAME=Escala Negocios Digitais LTDA

# ─── BENCHMARKS ──────────────────────────────────────────────────────
BENCHMARK_LEAD_TO_TRIAGEM=0.95
BENCHMARK_TRIAGEM_TO_PROPOSTA=0.40
BENCHMARK_PROPOSTA_TO_NEGOCIACAO=0.60
BENCHMARK_NEGOCIACAO_TO_FECHADO=0.30
THRESHOLD_CPL_GREEN_MAX=10
THRESHOLD_CPL_YELLOW_MAX=15
THRESHOLD_RESPONSE_TIME_GREEN_SEC=60
THRESHOLD_RESPONSE_TIME_YELLOW_SEC=300
THRESHOLD_FREQUENCY_WARNING=3
THRESHOLD_CTR_DROP_PCT=20
DASHBOARD_REFRESH_INTERVAL_MIN=30
DASHBOARD_CACHE_TTL_MIN=15

# ─── EXPOR PARA VITE (frontend) ──────────────────────────────────────
# Estas variáveis precisam do prefixo VITE_ para serem acessíveis no browser
VITE_DASHBOARD_API_URL=https://n8n.escalanegociosdigitais.com.br/webhook/dashboard/revert
# VITE_DASHBOARD_API_TOKEN é o mesmo que DASHBOARD_API_TOKEN
# VITE_DASHBOARD_PASSWORD_HASH é o bcrypt da DASHBOARD_PASSWORD_RAW
